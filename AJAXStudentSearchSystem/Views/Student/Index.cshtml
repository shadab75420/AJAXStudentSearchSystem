@{
    ViewData["Title"] = "Student Search";
}

<!DOCTYPE html>
<html>
<head>
    <title>AJAX Student Search</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- jQuery CDN -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>

<body>

    <div class="container mt-5">

        <h2 class="text-center mb-4">
            AJAX Based Student Registration Search System
        </h2>

        <div class="card p-4 shadow">

            <div class="mb-3">
                <label class="form-label">
                    Enter Student ID
                </label>

                <input type="number"
                       id="studentId"
                       class="form-control"
                       placeholder="Enter Student ID" />
            </div>

            <button id="searchBtn"
                    class="btn btn-primary">
                Search Student
            </button>

            <hr />

            <!-- Result Area -->
            <div id="result"></div>

        </div>

    </div>

    <script>

        $(document).ready(function () {

        $("#searchBtn").click(function () {

        let studentId = $("#studentId").val();

        // Validation
        if (studentId == "") {

        $("#result").html(`
        <div class="alert alert-danger">
        Please enter Student ID
        </div>
        `);

        return;
        }

        // AJAX Request
        $.ajax({

        url: '/Student/GetStudentById',

        type: 'GET',

        data: { id: studentId },

        success: function (response) {

        // Student Found
        if (response.success) {

        let student = response.data;

        $("#result").html(`
        <div class="alert alert-success">

        <h4>Student Details</h4>

        <p>
        <strong>ID:</strong>
        ${student.studentId}
        </p>

        <p>
        <strong>Name:</strong>
        ${student.name}
        </p>

        <p>
        <strong>Department:</strong>
        ${student.department}
        </p>

        <p>
        <strong>Email:</strong>
        ${student.email}
        </p>

        <p>
        <strong>City:</strong>
        ${student.city}
        </p>

        </div>
        `);
        }

        // Student Not Found
        else {

        $("#result").html(`
        <div class="alert alert-warning">
        ${response.message}
        </div>
        `);
        }
        },

        error: function () {

        $("#result").html(`
        <div class="alert alert-danger">
        Error occurred while fetching data
        </div>
        `);
        }
        });

        });

        });

    </script>

</body>
</html>